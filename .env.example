# SNMP Walker -- optional overrides
# Copy this file to .env and uncomment lines you want to change.
# All launchers load this file automatically before starting python.

# Pre-populate the community strings field in the web form.
# Comma-separated. Quote-free. Loaded on every page load.
# SNMP_WALKER_COMMUNITIES=public,private,snmpro

# Bind address (default 127.0.0.1 for local; 0.0.0.0 to serve on the network)
# SNMP_WALKER_HOST=127.0.0.1

# TCP port (default 5055)
# SNMP_WALKER_PORT=5055

# Set to false to suppress automatic browser launch
# SNMP_WALKER_OPEN_BROWSER=true

# Use Waitress production server instead of Flask dev server
# SNMP_WALKER_PRODUCTION=false

# Enable verbose DEBUG logging to snmp_walker.log
# SNMP_WALKER_DEBUG=false

# WSL/Linux: override the Python binary used to create the venv.
# SNMP_WALKER_PYTHON=/usr/bin/python3

# WSL/Linux: default install copies the app into the venv for more reliable server runs.
# Set this only when actively editing code and wanting editable install behavior.
# SNMP_WALKER_EDITABLE=false

# WSL/Linux: override or disable the no-admin uv fallback.
# The launchers use uv only when Python venv/pip is missing.
# SNMP_WALKER_UV=/path/to/uv
# SNMP_WALKER_UV_AUTO_INSTALL=true
# When running under WSL from /mnt/c, the default tools dir is under ~/.cache/snmp-walker.
# SNMP_WALKER_TOOLS_DIR=.tools

# WSL/Linux: override the venv directory name.
# If you ran run.bat first, .venv is a Windows venv and the bash scripts
# will auto-switch to .venv-wsl. Set this explicitly if you want a different name.
# When running under WSL from /mnt/c, the default venv is under ~/.cache/snmp-walker.
# SNMP_WALKER_VENV=.venv-wsl
